{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HJSON",
  "scopeName": "source.hjson",
  "patterns": [
    { "include": "#comments" },
    { "include": "#object" },
    { "include": "#array" },
    { "include": "#value" }
  ],
  "repository": {

    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.hjson",
          "match": "#[^\\n]*"
        },
        {
          "name": "comment.line.double-slash.hjson",
          "match": "//[^\\n]*"
        },
        {
          "name": "comment.block.hjson",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.hjson" } },
          "endCaptures": { "0": { "name": "punctuation.definition.comment.end.hjson" } }
        }
      ]
    },

    "object": {
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": { "0": { "name": "punctuation.definition.dictionary.begin.hjson" } },
      "endCaptures": { "0": { "name": "punctuation.definition.dictionary.end.hjson" } },
      "patterns": [
        { "include": "#comments" },
        { "include": "#key-value-pair" },
        { "include": "#comma" }
      ]
    },

    "array": {
      "begin": "\\[",
      "end": "\\]",
      "beginCaptures": { "0": { "name": "punctuation.definition.array.begin.hjson" } },
      "endCaptures": { "0": { "name": "punctuation.definition.array.end.hjson" } },
      "patterns": [
        { "include": "#comments" },
        { "include": "#value" },
        { "include": "#comma" },
        { "include": "#unquoted-array-value" }
      ]
    },

    "key-value-pair": {
      "comment": "Matches: key: value, key [attrs]: value, or \"key\": value",
      "patterns": [
        { "include": "#quoted-key-value-pair" },
        { "include": "#unquoted-key-value-pair" }
      ]
    },

    "quoted-key-value-pair": {
      "comment": "Matches: \"key\": value",
      "begin": "(\"[^\"]*\")(\\s*)(\\:)",
      "end": "(?=\\s*[,}\\]])|(?=\\s*$)|(?=\\s*[#/])",
      "beginCaptures": {
        "1": { "name": "support.type.property-name.hjson" },
        "3": { "name": "punctuation.separator.dictionary.key-value.hjson" }
      },
      "patterns": [
        { "include": "#comments" },
        { "include": "#value" },
        { "include": "#unquoted-string-value" }
      ]
    },

    "unquoted-key-value-pair": {
      "comment": "Matches: key: value or key [attrs]: value — key is unquoted identifier",
      "begin": "([a-zA-Z_@][a-zA-Z0-9_.]*)(\\s*(?:\\[[^\\]]*\\])?\\s*)(\\:)",
      "end": "(?=\\s*[,}\\]])|(?=\\s*$)|(?=\\s*[#/])",
      "beginCaptures": {
        "1": { "name": "support.type.property-name.hjson" },
        "2": { "name": "entity.other.attribute-name.hjson" },
        "3": { "name": "punctuation.separator.dictionary.key-value.hjson" }
      },
      "patterns": [
        { "include": "#comments" },
        { "include": "#value" },
        { "include": "#unquoted-string-value" }
      ]
    },

    "value": {
      "comment": "All value types that can appear after a colon or in an array",
      "patterns": [
        { "include": "#string-multiline" },
        { "include": "#string-double-quoted" },
        { "include": "#constant" },
        { "include": "#number" },
        { "include": "#object" },
        { "include": "#array" }
      ]
    },

    "string-double-quoted": {
      "name": "string.quoted.double.hjson",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.hjson" } },
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.hjson" } },
      "patterns": [
        {
          "name": "constant.character.escape.hjson",
          "match": "\\\\(?:[\"\\\\/bfnrt]|u[0-9a-fA-F]{4})"
        }
      ]
    },

    "string-multiline": {
      "name": "string.quoted.multiline.hjson",
      "begin": "'''",
      "end": "'''",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.hjson" } },
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.hjson" } }
    },

    "number": {
      "name": "constant.numeric.hjson",
      "match": "-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?(?=\\s*[,}\\]#/\\n]|\\s*$)"
    },

    "constant": {
      "name": "constant.language.hjson",
      "match": "\\b(?:true|false|null)\\b"
    },

    "comma": {
      "name": "punctuation.separator.comma.hjson",
      "match": ","
    },

    "unquoted-string-value": {
      "comment": "Unquoted string value after a colon — matches rest of line that is not a structured value",
      "name": "string.unquoted.hjson",
      "match": "(?<=:\\s*)[^\\s{\\[\"'][^,}\\]\\n#/]*[^\\s,}\\]#/]|(?<=:\\s*)[^\\s{\\[\"',}\\]\\n#/]"
    },

    "unquoted-array-value": {
      "comment": "Unquoted string value inside an array — a line that is not a structured value",
      "name": "string.unquoted.hjson",
      "match": "[a-zA-Z_][a-zA-Z0-9_ ]*(?=\\s*$|\\s*[,\\]#/])"
    }
  }
}