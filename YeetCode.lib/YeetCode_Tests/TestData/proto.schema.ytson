{
  @Field: {
    type: string
    tag: int
    label [optional, default:optional]: string
    deprecated [default:false]: bool
  }

  package [optional]: string
  syntax [default:proto3]: string
  messages [optional]: {
    @: {
      fields: {
        @: @Field
      }
    }
  }
  enums [optional]: {}
}